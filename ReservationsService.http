### 2. Crear Inventario con Configuración de Slots Dinámicos
POST {{baseUrl}}/api/reservations/inventory
Content-Type: application/json

{
  "name": "Mesa VIP - Terraza Dinámica",
  "minCapacity": 2,
  "maxCapacity": 6,
  "startTime": "14:00:00",
  "endTime": "22:00:00",
  "dateTerm": "2026-04-13T00:00:00Z",
  "price": 20.00,
  "weekDays": "1,1,1,1,1,0,0",
  "slotInterval": 30,
  "inventoryTypeId": 1,
  "consumptionCenterId": 1,
  "status": 0,
  "generateSlots": false,
  "slotConfigs": [
    {
      "availabilityType": 1, 
      "durationMinutes": 15,
      "order": 1
    },
    {
      "availabilityType": 2,
      "durationMinutes": 10,
      "order": 2
    }
  ]
}

