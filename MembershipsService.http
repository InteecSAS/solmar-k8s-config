###
# Send Vacation Exchange Notification
# vacationExchange: 0 for RCI, 1 for Interval, 3 for Thrid Home
POST {{baseUrl}}/api/memberships/features/vacation-exchange-notification
Content-Type: application/json
Authorization: {{jwt}}

{
  "vacationExchange": 0,
  "memberName": "John Doe",
  "memberEmail": "diurvan1@gmail.com",
  "memberContactNumber": "",
  "contractId": "C-12345",
  "membershipId": "M-12345",
  "exchangeType": "RCI",
  "usageYear": "2024",
  "accelerationYear": "2025",
  "unitType": "Villa",
  "unitNumber": "V-123",
  "weekNumber": 23
}


###
# Send Special Occasion Notification
# contactType: "Email", "Call" and "Lobby"
POST {{baseUrl}}/api/memberships/features/special-occasions-notification
Content-Type: application/json
Authorization: {{jwt}}

{
  "consumptionCenterGroupId": "1",
  "contactType": "Email",
  "ContactDate": "01/01/2024",
  "ContactTime": "07:00AM"
}


###
# Send Membership Request Notification
# contactType: "Email", "Phone"
