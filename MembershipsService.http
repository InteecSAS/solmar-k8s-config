###
# Send Vacation Exchange Notification
# vacationExchange: 0 for RCI, 1 for Interval, 3 for Thrid Home
POST {{baseUrl}}/api/memberships/features/vacation-exchange-notification
Content-Type: application/json
Authorization: {{jwt}}

{
  "vacationExchange": 0,
  "memberName": "John Doe",
  "memberEmail": "diurvan1@gmail.com",
  "memberContactNumber": "955478664",
  "contractId": "C-12345",
  "membershipId": "M-12345",
  "exchangeType": "RCI",
  "usageYear": "2024",
  "accelerationYear": "2025",
  "unitType": "Villa",
  "unitNumber": "V-123",
  "weekNumber": 23
}
