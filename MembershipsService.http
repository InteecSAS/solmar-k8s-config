###
# Create a new Co-Member Invitation
POST {{baseUrl}}/api/memberships/features/comember-invitations
Content-Type: application/json
Authorization: {{jwt}}

{
  "contractId": "C-12345",
  "coMemberPersonId": 56138,
  "email": "diurvan1@gmail.com",
  "phoneNumber": "955478664",
  "fullName": "Nombre comember"
}

###
# Get a Co-Member Invitation
GET {{baseUrl}}/api/memberships/features/comember-invitations
Content-Type: application/json
Authorization: {{jwt}}


###
# Update a Co-Member Invitation's status
# This endpoint allows you to update the status of a co-member invitation. You can accept or reject the invitation by setting the "status" field accordingly.
# For example, to accept the invitation, set "status" to "ACCEPTED". To reject, set it to "REJECTED".
PUT {{baseUrl}}/api/memberships/features/comember-invitations/1
Content-Type: application/json
Authorization: {{jwt}}

{
  "status": "ACCEPTED"
}

###
# Create a new Guest
POST {{baseUrl}}/api/memberships/features/guests
Content-Type: application/json
Authorization: {{jwt}}

[
  {
    "contractId": "104581",
    "reservationNumber": "1344414",
    "fullName": "asdasdasd",
    "email": "asdasd@asdasd.com",
    "phoneNumber": "1212121212",
    "address": "asdasdasd",
    "relationship": "Parent",
    "useReservationInAbsence": true
  },
  {
    "contractId": "104581-2",
    "reservationNumber": "1344414-2",
    "fullName": "asdasdasd-2",
    "email": "asdasd@asdasd.com-2",
    "phoneNumber": "1212121212-2",
    "address": "asdasdasd-2",
    "relationship": "Parent-2",
    "useReservationInAbsence": false
  }
]

