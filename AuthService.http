# =====================================================
# Auth Controller
# Endpoints públicos para autenticación y registro.
# =====================================================

##/api/auth-service/client/8321caef-cfca-4fe7-aa97-868cd36a4226
GET {{baseUrl}}/api/auth-service/client/8321caef-cfca-4fe7-aa97-868cd36a4226
Authorization: {{cliente_jwt}}

###
# @name initiateRegistration
# Inicia el proceso de registro, validando códigos de reserva/membresía y enviando un código de verificación.
# registrationType: "reservation", "membership", "direct
# membershipCode: Required if registrationType is "membership"
# reservationCode: Required if registrationType is "reservation"
POST {{baseUrl}}/api/auth-service/initiate-registration
Content-Type: application/json
Accept-Language: en-US

{
  "email": "angelicasl@hotmail.com",
  "registrationType": "membership",
  "reservationCode": "72270",
  "AcceptTerms": true,
  "AcceptDataPolicy": true
}

###

# @name verifyRegistrationCode
# Verifica el código de registro enviado al correo electrónico del usuario.
# code: The 6-digit code received via email
POST {{baseUrl}}/api/auth-service/verify-registration-code
Content-Type: application/json

{
  "email": "ivan.tapia@inteec.la",
  "code": "564800"
}

###

### @name register
# Registra un nuevo usuario con el rol "Cliente" por defecto.
# Este endpoint debe ser llamado DESPUÉS de una verificación exitosa del correo electrónico (si aplica).
# registrationType: "reservation", "membership", "direct" - debe coincidir con el tipo usado en initiate-registration
# deviceToken: Opcional. Token de registro del dispositivo para notificaciones push.
POST {{baseUrl}}/api/auth-service/register
Content-Type: application/json

{
  "firstName": "Iván",
  "lastName": "Tapia",
  "email": "ivan.tapia@inteec.la",
  "password": "P@ssw0rd",
  "birthDate" : "1976-12-01",
  "nationality" : "Mexico",
  "gender" : "Masculino",
  "phoneNumber" : "+51955478664",
  "registrationType": "direct",
  "deviceToken": "device_token",
  "AcceptTerms": true,
  "AcceptDataPolicy": true
}

###
## RESPONSE EXAMPLE:
## HTTP/1.1 200 OK
## Content-Type: application/json; charset=utf-8
##
## {
##   "message": "User created successfully!"
## }


# @name login
# Inicia sesión y obtiene un par de tokens (Access Token + Refresh Token).
# accessToken (Token): Corta duración (e.g. 15 min). Para peticiones diarias.
# refreshToken: Larga duración (e.g. 7 días). Para renovar el Access Token.
POST {{baseUrl}}/api/auth-service/login
Content-Type: application/json
X-Api-Key: {{x-api-key}}

{
  "email": "ivan.tapia@inteec.la",
  "password": "P@ssw0rd",
  "deviceToken": "your_device_token_here_for_login"
}

###
# RESPONSE EXAMPLE:
# HTTP/1.1 200 OK
# Content-Type: application/json; charset=utf-8
#
# {
#   "token": "eyJhbGciOiJIUzUxMiI...",
#   "refreshToken": "9a12b-34cd-56ef...",
#   "user": { "id": "...", "email": "..." },
#   "customerProfile": null
# }

###

# @name refreshToken
# Obtiene un nuevo par de tokens usando un Refresh Token válido.
# Este endpoint implementa "Token Rotation" (el refresh token enviado queda invalidado).
POST {{baseUrl}}/api/auth-service/refresh-token
Content-Type: application/json
X-Api-Key: {{x-api-key}}

{
  "refreshToken": "9a12b-34cd-56ef..."
}

###
# RESPONSE EXAMPLE:
# HTTP/1.1 200 OK
#
# {
#   "token": "NUEVO_ACCESS_TOKEN",
#   "refreshToken": "NUEVO_REFRESH_TOKEN"
# }


# @name updateDeviceToken
# [NUEVO] Registra o actualiza el token de un dispositivo para notificaciones push para el usuario autenticado.
# Este endpoint debe ser llamado por la aplicación cliente cuando obtiene un nuevo token de dispositivo
# o cuando el usuario inicia sesión/se registra.
POST {{baseUrl}}/api/auth-service/device-token
Content-Type: application/json
Authorization: {{cliente_jwt}} # O el token del usuario autenticado

{
  "deviceToken": "your_new_or_updated_device_token_here"
}

###
# RESPONSE EXAMPLE:
# HTTP/1.1 200 OK
# Content-Type: application/json; charset=utf-8
#
# {
#   "message": "Device token actualizado exitosamente."
# }


# @name forgotPassword
# Inicia el proceso de reseteo de contraseña.
POST {{baseUrl}}/api/auth-service/forgot-password
Content-Type: application/json

{
  "email": "diurvan1@gmail.com"
}

###
# @name resetPassword
# Resetea la contraseña usando el token obtenido de "forgot-password".
POST {{baseUrl}}/api/auth-service/reset-password
Content-Type: application/json

{
  "email": "diurvan1@gmail.com",
  "code": "578855",
  "newPassword": "P@ssw0rd"
}


###
### RESPONSE EXAMPLE:
### HTTP/1.1 200 OK
# Content-Type: application/json; charset=utf-8
#
# {
#   "message": "Password has been reset successfully."
# }

###

# @name validateSecurityStamp
# [USO INTERNO] Valida el security stamp de un usuario.
# Usado por el API Gateway para verificar si un token sigue siendo válido.
GET {{baseUrl}}/api/auth-service/internal/validate-security-stamp/1/2027-01-01T00:00:00Z

# RESPONSE EXAMPLE (VALID):
# HTTP/1.1 200 OK
# Content-Type: application/json; charset=utf-8
#
# true

# RESPONSE EXAMPLE (INVALID):
# HTTP/1.1 200 OK
# Content-Type: application/json; charset=utf-8
#
# false

###
# =====================================================
# Admin Controller
# Requiere un token JWT con el rol "AdministradorSistema".
# =====================================================

# @name getUsers
# Obtiene una lista de todos los usuarios.
GET {{baseUrl}}/api/auth-service/users
Authorization: {{cliente_jwt}}

# RESPONSE EXAMPLE:
# HTTP/1.1 200 OK
# Content-Type: application/json; charset=utf-8
#
# [
#   {
#     "firstName": "Admin",
#     "lastName": "Solmar",
#     ...
#     "email": "admin@solmar.com",
#     ...
#   }
# ]

###

# @name getRoles
# Obtiene una lista de todos los roles.
GET {{baseUrl}}/api/auth-service/roles
Authorization: {{cliente_jwt}}

# RESPONSE EXAMPLE:
# HTTP/1.1 200 OK
# Content-Type: application/json; charset=utf-8
#
# [
#   {
#     "id": "a1b2c3d4-...",
#     "name": "AdministradorSistema",
#     "normalizedName": "ADMINISTRADORSISTEMA",
#     "concurrencyStamp": "..."
#   }
# ]

###

# @name createRole
# Crea un nuevo rol de seguridad.
POST {{baseUrl}}/api/auth-service/roles
Content-Type: application/json
Authorization: {{cliente_jwt}}


###

# @name updateMyPreferences
# Actualiza las preferencias del usuario actual.
PUT {{baseUrl}}/api/auth-service/preferences/me
Authorization: {{cliente_jwt}}
Content-Type: application/json

{
  "receiveEmailNotifications": true,
  "allowAnalyticsCookies": true,
  "preferredLanguage": "es-MX"
}

###

# @name getPreferenceCategories
# Obtiene todas las categorías de preferencias disponibles con sus opciones, traducidas según el idioma solicitado.
GET {{baseUrl}}/api/auth-service/preferences/categories
Authorization: {{cliente_jwt}}
Accept-Language: en-US

###

# @name getPreferenceCategories_en
# Obtiene todas las categorías de preferencias disponibles con sus opciones, traducidas a inglés.
GET {{baseUrl}}/api/auth-service/preferences/categories
Authorization: {{cliente_jwt}}
Accept-Language: en-US

###

# @name getMyPreferenceSelections
# Obtiene las preferencias detalladas seleccionadas por el usuario actual.
GET {{baseUrl}}/api/auth-service/preferences/me/selections
Authorization: {{cliente_jwt}}
Accept-Language: en-US

###
# @name getUserPreferenceSelections
# Obtiene las preferencias detalladas seleccionadas por el usuario.
GET {{baseUrl}}/api/auth-service/preferences/user/selections/78341668-c8a5-4fe2-80b4-148d482ab6da
Authorization: {{cliente_jwt}}


###

# @name updateMyPreferenceSelections
# Actualiza las preferencias seleccionadas por el usuario actual.
PUT {{baseUrl}}/api/auth-service/preferences/me/selections
Authorization: {{cliente_jwt}}
Content-Type: application/json

{
  "selectedPreferenceOptionIds": [
    1,
    3,
    5
  ]
}

# Archivo de peticiones para ReservationService a través del YARP Proxy
# =================================================================
# Todas las peticiones apuntan al YARP Proxy.
#
# Estructura de la URL:
# {{baseUrl}}/reservation/{endpoint}
#
# Ejemplo:
# {{baseUrl}}/reservation/indicadores -> (YARP) -> ReservationService/indicadores
# =================================================================
###

## @name getProfile
# Obtiene Profile information del usuario autenticado
GET {{baseUrl}}/api/auth-service/user/profile
Authorization: {{cliente_jwt}}
X-Api-Key: {{x-api-key}}